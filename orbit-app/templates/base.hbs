<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}} | {{site_title}}</title>
  {{#if description}}<meta name="description" content="{{description}}">{{/if}}
  <style>
    :root {
      color-scheme: light;
      --ink: #15171a;
      --muted: #5d6673;
      --line: #d9dee7;
      --paper: #fbfcfe;
      --panel: #ffffff;
      --night: #10151f;
      --night-soft: #182230;
      --blue: #2b6cff;
      --teal: #00a78e;
      --amber: #c07a00;
      --rose: #d6456f;
      --code: #0f1623;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.65;
      color: var(--ink);
      background: var(--paper);
    }
    a { color: var(--blue); text-decoration-thickness: 0.08em; text-underline-offset: 0.18em; }
    img { max-width: 100%; }
    code {
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 0.94em;
      background: #eef2f7;
      border: 1px solid #dfe5ee;
      border-radius: 5px;
      padding: 0.1rem 0.32rem;
    }
    pre {
      overflow-x: auto;
      background: var(--code);
      color: #edf5ff;
      border: 1px solid #253248;
      border-radius: 8px;
      padding: 1rem;
      line-height: 1.5;
    }
    pre code { background: transparent; border: 0; padding: 0; color: inherit; }
    .site-header {
      position: sticky;
      top: 0;
      z-index: 10;
      border-bottom: 1px solid rgba(21, 23, 26, 0.08);
      background: rgba(251, 252, 254, 0.92);
      backdrop-filter: blur(14px);
    }
    .nav {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0.85rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      color: var(--ink);
      font-weight: 800;
      text-decoration: none;
    }
    .brand-mark {
      width: 2rem;
      height: 2rem;
      display: grid;
      place-items: center;
      border: 1px solid #263246;
      border-radius: 8px;
      color: #fff;
      background: linear-gradient(135deg, var(--night), #214a42);
      font-size: 1.05rem;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.95rem;
    }
    .nav-links a { color: var(--muted); text-decoration: none; font-weight: 650; }
    .nav-links a:hover { color: var(--ink); }
    main { min-height: 70vh; }
    article > :not(.hero):not(.band):not(.full-bleed) {
      max-width: 880px;
      margin-left: auto;
      margin-right: auto;
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
    article > h1,
    article > h2,
    article > h3 { line-height: 1.16; letter-spacing: 0; }
    article > h1 { margin-top: 3rem; font-size: clamp(2.25rem, 8vw, 4.75rem); }
    article > h2 { margin-top: 3rem; font-size: 2rem; }
    article > h3 { margin-top: 2rem; font-size: 1.35rem; }
    article > p, article > ul, article > ol { color: var(--muted); }
    .hero {
      min-height: calc(100vh - 64px);
      display: grid;
      align-items: center;
      background: var(--night);
      color: #fff;
      overflow: hidden;
    }
    .hero-inner {
      width: min(1120px, 100%);
      margin: 0 auto;
      padding: 5rem 1.25rem 4rem;
      display: grid;
      grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.82fr);
      gap: 3rem;
      align-items: center;
    }
    .eyebrow {
      margin: 0 0 1rem;
      color: #91f0d7;
      font-weight: 760;
      text-transform: uppercase;
      letter-spacing: 0;
      font-size: 0.82rem;
    }
    .hero h1 {
      margin: 0;
      max-width: 760px;
      font-size: clamp(3.2rem, 9vw, 7rem);
      line-height: 0.94;
      letter-spacing: 0;
    }
    .hero-copy {
      max-width: 650px;
      margin: 1.35rem 0 0;
      color: #c9d4e5;
      font-size: clamp(1.05rem, 2vw, 1.28rem);
    }
    .hero-actions {
      margin-top: 1.65rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .hero-proof {
      margin-top: 2rem;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
      max-width: 650px;
    }
    .proof-item {
      border-top: 1px solid #2b374b;
      padding-top: 0.75rem;
      color: #94a3b8;
      font-size: 0.9rem;
    }
    .proof-item strong { display: block; color: #fff; font-size: 1.15rem; }
    .orbit-stage {
      min-height: 470px;
      position: relative;
      display: grid;
      place-items: center;
    }
    .orbit-ring {
      position: absolute;
      border: 1px solid rgba(145, 240, 215, 0.34);
      border-radius: 999px;
      transform: rotate(-18deg);
    }
    .orbit-ring.one { width: 92%; height: 54%; }
    .orbit-ring.two { width: 72%; height: 42%; border-color: rgba(43, 108, 255, 0.42); transform: rotate(18deg); }
    .orbit-ring.three { width: 48%; height: 30%; border-color: rgba(214, 69, 111, 0.42); transform: rotate(48deg); }
    .planet {
      position: absolute;
      width: 0.9rem;
      height: 0.9rem;
      border-radius: 999px;
      background: var(--teal);
      box-shadow: 0 0 28px rgba(0, 167, 142, 0.8);
    }
    .planet.blue { background: var(--blue); left: 15%; top: 37%; }
    .planet.green { right: 18%; top: 24%; }
    .planet.rose { background: var(--rose); right: 28%; bottom: 20%; }
    .terminal {
      width: min(440px, 100%);
      border: 1px solid #303d55;
      border-radius: 8px;
      background: rgba(15, 22, 35, 0.94);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.34);
      overflow: hidden;
    }
    .terminal-bar {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      border-bottom: 1px solid #303d55;
      padding: 0.75rem 0.9rem;
      color: #9aa7bd;
      font-size: 0.82rem;
    }
    .dot { width: 0.62rem; height: 0.62rem; border-radius: 999px; background: #ff5f57; }
    .dot:nth-child(2) { background: #febc2e; }
    .dot:nth-child(3) { background: #28c840; margin-right: 0.35rem; }
    .terminal pre {
      margin: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      min-height: 240px;
    }
    .terminal .ok { color: #91f0d7; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      padding: 0.72rem 1rem;
      border: 1px solid #1f2a3d;
      border-radius: 8px;
      background: var(--ink);
      color: #fff;
      text-decoration: none;
      font-weight: 760;
    }
    .btn:hover { background: #2a3038; }
    .btn-secondary { background: #fff; color: var(--ink); border-color: var(--line); }
    .btn-secondary:hover { background: #f1f5f9; }
    .hero .btn-secondary { background: transparent; color: #fff; border-color: #536179; }
    .hero .btn-secondary:hover { background: rgba(255,255,255,0.08); }
    .band {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: #fff;
      margin: 0;
      padding: 4rem 0;
    }
    .band-inner {
      width: min(1120px, 100%);
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    .section-kicker {
      margin: 0 0 0.6rem;
      color: var(--teal);
      font-weight: 780;
      text-transform: uppercase;
      font-size: 0.78rem;
    }
    .section-title {
      margin: 0;
      max-width: 760px;
      font-size: clamp(2rem, 5vw, 3.6rem);
      line-height: 1.02;
    }
    .section-lede {
      max-width: 720px;
      color: var(--muted);
      font-size: 1.08rem;
    }
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }
    .feature, .card, .step, .command-card {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--panel);
      padding: 1.25rem;
    }
    .feature-icon {
      width: 2.35rem;
      height: 2.35rem;
      display: grid;
      place-items: center;
      border-radius: 8px;
      background: #e9f7f4;
      color: var(--teal);
      font-weight: 900;
    }
    .feature h3, .card-title, .step h3, .command-card h3 {
      margin: 0.9rem 0 0.45rem;
      font-size: 1.08rem;
      line-height: 1.25;
    }
    .feature p, .card-body, .step p, .command-card p { color: var(--muted); }
    .card { margin: 1.25rem auto; max-width: 880px; }
    .alert {
      max-width: 880px;
      margin: 1.5rem auto;
      padding: 1rem 1.25rem;
      border: 1px solid var(--line);
      border-left: 4px solid var(--blue);
      border-radius: 8px;
      background: #f5f8ff;
    }
    .alert-warning { border-left-color: var(--amber); background: #fff8e7; }
    .alert-info { border-left-color: var(--blue); }
    .alert-success { border-left-color: var(--teal); background: #ecfbf7; }
    .alert-title { display: block; margin-bottom: 0.35rem; color: var(--ink); }
    .alert-body > :first-child { margin-top: 0; }
    .alert-body > :last-child { margin-bottom: 0; }
    .steps {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }
    .step-number {
      width: 2rem;
      height: 2rem;
      display: grid;
      place-items: center;
      border-radius: 999px;
      color: #fff;
      background: var(--blue);
      font-weight: 800;
    }
    .command-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .command-card code { display: inline-block; margin-bottom: 0.25rem; }
    .site-footer {
      border-top: 1px solid var(--line);
      padding: 2rem 1.25rem;
      color: var(--muted);
      text-align: center;
    }
    @media (max-width: 860px) {
      .hero-inner { grid-template-columns: 1fr; padding-top: 3.5rem; }
      .orbit-stage { min-height: 340px; }
      .feature-grid, .steps, .command-grid { grid-template-columns: 1fr; }
      .hero-proof { grid-template-columns: 1fr; }
      .nav { align-items: flex-start; flex-direction: column; }
      .nav-links { flex-wrap: wrap; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <nav class="nav" aria-label="Primary navigation">
      <a class="brand" href="/">
        <span class="brand-mark">O</span>
        <span>{{site_title}}</span>
      </a>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/docs/getting-started.html">Docs</a>
        <a href="/docs/components.html">Components</a>
        <a href="/docs/configuration.html">Config</a>
        <a href="https://crates.io/crates/orbit-md">Crate</a>
      </div>
    </nav>
  </header>
  <main>
    <article>{{{content}}}</article>
  </main>
  <footer class="site-footer">
    Built with Orbit. Published as <code>orbit-md</code> on crates.io.
  </footer>
</body>
</html>
